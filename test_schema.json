{
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "用户姓名"
    },
    "age": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "用户年龄"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "用户邮箱"
    },
    "status": {
      "type": "string",
      "enum": ["active", "inactive", "pending"],
      "description": "用户状态"
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "用户分数"
    }
  },
  "required": ["name", "age", "email"]
}