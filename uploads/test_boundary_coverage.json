{
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1000
    },
    "age": {
      "type": "integer",
      "minimum": 0,
      "maximum": 120
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "multipleOf": 0.5
    },
    "name": {
      "type": "string",
      "minLength": 2,
      "maxLength": 50
    },
    "email": {
      "type": "string",
      "format": "email",
      "minLength": 5,
      "maxLength": 100
    },
    "status": {
      "type": "string",
      "enum": ["active", "inactive", "pending"]
    },
    "balance": {
      "type": "number",
      "minimum": 0,
      "maximum": 100000
    },
    "count": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100
    }
  },
  "required": ["id", "name", "email", "status"]
}