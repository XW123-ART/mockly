{
  "type": "object",
  "properties": {
    "order_id": {
      "type": "string",
      "pattern": "^ORD\\d{8}$"
    },
    "customer_id": {
      "type": "string",
      "pattern": "^C\\d{6}$"
    },
    "total_amount": {
      "type": "number",
      "minimum": 0.01
    },
    "order_date": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": ["pending", "processing", "shipped", "delivered", "cancelled"]
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "product_id": {
            "type": "string"
          },
          "quantity": {
            "type": "integer",
            "minimum": 1
          },
          "unit_price": {
            "type": "number",
            "minimum": 0.01
          }
        },
        "required": ["product_id", "quantity", "unit_price"]
      },
      "minItems": 1
    }
  },
  "required": ["order_id", "customer_id", "total_amount", "order_date", "status", "items"]
}