{
  "type": "object",
  "properties": {
    "device_id": {
      "type": "string",
      "pattern": "^DEV-\\d{6}$"
    },
    "name": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": ["smartphone", "laptop", "tablet", "watch", "speaker"]
    },
    "brand": {
      "type": "string"
    },
    "model": {
      "type": "string"
    },
    "serial_number": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["active", "inactive", "maintenance", "retired"]
    },
    "purchase_date": {
      "type": "string",
      "format": "date"
    },
    "warranty_expiry": {
      "type": "string",
      "format": "date"
    }
  },
  "required": ["device_id", "name", "type", "brand", "model", "serial_number", "status", "purchase_date"]
}